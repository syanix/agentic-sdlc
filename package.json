{
  "name": "create-agentic-project",
  "version": "0.1.0",
  "description": "Scaffold a Claude Code agentic project with tech-stack-specific agents, commands, skills, and hooks",
  "type": "module",
  "bin": {
    "create-agentic-project": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "keywords": [
    "claude",
    "agentic",
    "scaffolder",
    "cli",
    "code-generation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
